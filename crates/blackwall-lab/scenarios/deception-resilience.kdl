// Deception resilience under load: a connection flood drives completed TCP
// sessions past the engine's cap while a background packet flood hits nft. This
// is a CORRECTNESS/resilience gate (not a stress benchmark, see issue #67): it
// proves the engine's drop-at-cap defense is enforced, legit deception still
// works, and the engine survives.
topology "deception-resilience" {
    node "victim" {
        run "engine" \
            cmd="target/debug/lab-tests/blackwall-deception-interop serves_deception_under_load --ignored --nocapture"
    }
    node "attacker" {
        run "wire-flood" \
            cmd="cargo run --offline -p blackwall-trafficgen -- send --dst 10.0.0.1 --spec full-set --duration 30"
    }
    link "victim" "attacker" subnet="10.0.0.0/30"
}

scenario "engine-survives-and-caps" {
    step wait   node="victim"   until="port-open:61000" timeout="30s"
    // Connection flood past the cap; self-asserts served>0 AND dropped+failed>0
    // (engine serving + bounding the flood) while the wire flood runs.
    step assert node="attacker" \
         cmd="cargo run --offline -p blackwall-trafficgen -- connect-flood --dst 10.0.0.1 --port 22 --concurrency 600 --duration 8" \
         exit="0" timeout="40s"
    // Legit deception still works + the engine survived (still responsive).
    step assert node="attacker" \
         cmd="timeout 5 bash -c 'exec 3<>/dev/tcp/10.0.0.1/22; head -c 40 <&3'" \
         contains="SSH-2.0" timeout="20s"
}
